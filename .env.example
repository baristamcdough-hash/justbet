# ============================================================================
# JustBet Sportsbook — Environment Variables (Kenya Localized)
# Built by P.o.Riot
# ============================================================================

# ── Database ──
DATABASE_URL=postgresql+asyncpg://justbet:justbet_secret@postgres:5432/justbet
POSTGRES_USER=justbet
POSTGRES_PASSWORD=justbet_secret
POSTGRES_DB=justbet

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── JWT ──
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Application ──
APP_NAME=JustBet
APP_ENV=development
DEBUG=true

# ── CORS ──
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ──
RATE_LIMIT_AUTH=100
RATE_LIMIT_ANON=30

# ── Admin Seeding (First Boot) ──
# Set these to auto-create the first admin account on empty database
FIRST_ADMIN_PHONE=0712345678
FIRST_ADMIN_PIN=1234
ADMIN_SECRET_TOKEN=change-this-to-a-secure-random-string

# ── Kenya Locale & Currency Limits (KES) ──
DEFAULT_CURRENCY=KES
MIN_STAKE=50
MAX_STAKE=500000
MIN_DEPOSIT=100
MAX_DEPOSIT=150000
MIN_WITHDRAWAL=100
MAX_WITHDRAWAL=70000
MAX_SELECTIONS=30
MAX_POTENTIAL_WIN=10000000
